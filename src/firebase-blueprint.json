{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application (client or lawyer).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user from Firebase Auth." },
        "name": { "type": "string", "description": "The full name of the user." },
        "phone": { "type": "string", "description": "The phone number of the user." },
        "role": { "type": "string", "enum": ["client", "lawyer"], "description": "The role of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the user was created." }
      },
      "required": ["uid", "name", "phone", "role", "createdAt"]
    },
    "Lawyer": {
      "title": "Lawyer",
      "description": "Represents a lawyer in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the lawyer." },
        "name": { "type": "string", "description": "The full name of the lawyer." },
        "specialty": { "type": "string", "description": "The legal specialty of the lawyer." },
        "rating": { "type": "number", "description": "The rating of the lawyer." },
        "experience": { "type": "number", "description": "Years of experience." },
        "location": { "type": "string", "description": "The location of the lawyer." },
        "bio": { "type": "string", "description": "A short biography of the lawyer." },
        "photoUrl": { "type": "string", "description": "The URL of the lawyer's photo." }
      },
      "required": ["uid", "name", "specialty", "rating", "experience", "location"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Represents a legal consultation session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the consultation." },
        "userId": { "type": "string", "description": "The ID of the user who initiated the consultation." },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "assistant"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the consultation was started." }
      },
      "required": ["id", "userId", "messages", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information."
    },
    "/lawyers/{lawyerId}": {
      "schema": "Lawyer",
      "description": "Stores lawyer profile information."
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Stores legal consultation sessions."
    }
  }
}
